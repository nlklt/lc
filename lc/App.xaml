<Application x:Class="lc.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:lc"
             xmlns:vm="clr-namespace:lc.ViewModels"
             xmlns:vp="clr-namespace:lc.Views.Pages"
             xmlns:conv="clr-namespace:lc.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Themes/Dark.xaml"/>
                                
                <ResourceDictionary Source="/Resources/Localisation/Language.ru.xaml"/>
                
                <ResourceDictionary Source="/Resources/Controls/Text.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/Button.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/ListBox.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/ComboBox.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/DatePicker.xaml"/>
                
                <ResourceDictionary Source="/Resources/Variants/Buttons.xaml"/>
                <ResourceDictionary Source="/Resources/Variants/Inputs.xaml"/>
                <ResourceDictionary Source="/Resources/Variants/CheckBoxes.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:MultiObjectConverter x:Key="MultiObjectConverter"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:CheckBoxStateToNullableBoolConverter x:Key="CheckBoxStateToNullableBoolConverter" />

            <DataTemplate DataType="{x:Type vm:MyBooksViewModel}">
                <vp:MyBooksView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
                <vp:CatalogView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AdminUsersViewModel}">
                <vp:AdminUsersView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:EditBookViewModel}">
                <vp:EditBookView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:EditChapterViewModel}">
                <vp:EditChapterView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:BookDetailsViewModel}">
                <vp:BookDetailsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                <vp:ProfileView />
            </DataTemplate>

            <Style x:Key="ModernScrollThumbStyle" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border CornerRadius="4" 
                                Background="{TemplateBinding BorderBrush}" 
                                Margin="2"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="Width" Value="12"/>
                <Setter Property="MinHeight" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track" IsDirectionReversed="true">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollThumbStyle}" 
                                           Background="{DynamicResource TransparentBrush}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Width" Value="Auto"/>
                                    <Setter Property="Height" Value="12"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollViewer">
                <Setter Property="PanningMode" Value="Both"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
