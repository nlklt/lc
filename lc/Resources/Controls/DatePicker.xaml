<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Стиль для подписи (без изменений, он рабочий) -->
    <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="8,8,8,4" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Основной стиль DatePicker -->
    <Style x:Key="DatePickerPlaceholderStyle" TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="SelectedDateFormat" Value="Short" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Grid>
                        <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" />

                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Важно: убираем стандартные эффекты наведения через переопределение стиля -->
                            <DatePickerTextBox x:Name="PART_TextBox"
                                           Grid.Column="0"
                                           HorizontalContentAlignment="Stretch"
                                           VerticalContentAlignment="Center"
                                           Focusable="{TemplateBinding Focusable}">
                                <DatePickerTextBox.Style>
                                    <Style TargetType="DatePickerTextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DatePickerTextBox">
                                                    <!-- Чистый контейнер для текста без системных триггеров -->
                                                    <ContentControl x:Name="PART_WatermarkHost" 
                                                                Focusable="False" 
                                                                IsHitTestVisible="False"
                                                                Margin="2,0"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <!-- Чтобы текст был виден, используем стандартный TextBox внутри если нужно, 
                                         но проще всего переопределить через базовый шаблон -->
                                        <Style.Triggers>
                                            <!-- Это блокирует "белое" свечение -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DatePickerTextBox.Style>
                            </DatePickerTextBox>

                            <!-- Текст-подсказка (Watermark) -->
                            <TextBlock x:Name="Watermark"
                                   Grid.Column="0"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="4,0"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed" />

                            <ToggleButton x:Name="PART_Button"
                                      Grid.Column="1"
                                      Focusable="False"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Width="20"
                                      Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <TextBlock Text="▼"
                                       FontSize="10"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </ToggleButton>
                        </Grid>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Реакция на наведение всего контрола -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}" />
                        </Trigger>

                        <Trigger Property="SelectedDate" Value="{x:Null}">
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>