<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета -->
    <Color x:Key="ColorPrimary">#0059FF</Color>
    <Color x:Key="ColorPrimaryHover">#FF4338CA</Color>
    <Color x:Key="ColorPrimaryPressed">#FF3730A3</Color>

    <Color x:Key="ColorSecondary">#FF2C2C30</Color>
    <Color x:Key="ColorSecondaryHover">#FF242428</Color>
    <Color x:Key="ColorSecondaryPressed">#000000</Color>

    <Color x:Key="ColorAccent">#1565C0</Color>

    <!-- Фон Background="#121212" -->
    <Color x:Key="ColorBackground">#0A0A0A</Color>
    <Color x:Key="ColorSurface">#1C1C1C</Color>
    <Color x:Key="ColorAltSurface">#2F2F2F</Color>

    <!-- Текст -->
    <Color x:Key="ColorTextPrimary">#BFBFBF</Color>
    <Color x:Key="ColorTextSecondary">#848489</Color>
    <Color x:Key="ColorTextMuted">#656568</Color>
    <Color x:Key="ColorTextInverse">#FBFBFB</Color>

    <!-- Границы -->
    <Color x:Key="ColorBorder">#3B3D45</Color>

    <!-- Состояния -->
    <Color x:Key="ColorSuccess">#00FF00</Color>
    <Color x:Key="ColorWarning">#FFA500</Color>
    <Color x:Key="ColorError">#FF0000</Color>
    <Color x:Key="ColorInfo">#FF3B82F6</Color>
</ResourceDictionary>