<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета (сделаны чуть насыщеннее для светлого фона) -->
    <Color x:Key="ColorPrimary">#0062FF</Color>
    <Color x:Key="ColorPrimaryHover">#0052D9</Color>
    <Color x:Key="ColorPrimaryPressed">#0045B5</Color>

    <!-- Вторичные цвета (в светлой теме это обычно светло-серые кнопки) -->
    <Color x:Key="ColorSecondary">#F0F0F2</Color>
    <Color x:Key="ColorSecondaryHover">#E2E2E6</Color>
    <Color x:Key="ColorSecondaryPressed">#D4D4D9</Color>

    <Color x:Key="ColorAccent">#1976D2</Color>

    <!-- Фон (светлые оттенки) -->
    <Color x:Key="ColorBackground">#F5F5F7</Color>
    <!-- Основной фон окна -->
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <!-- Карточки, вложенные панели -->
    <Color x:Key="ColorAltSurface">#E8E8ED</Color>
    <!-- Выделяющиеся элементы фона -->

    <!-- Текст (темные оттенки) -->
    <Color x:Key="ColorTextPrimary">#1D1D1F</Color>
    <!-- Почти черный -->
    <Color x:Key="ColorTextSecondary">#48484A</Color>
    <!-- Серый -->
    <Color x:Key="ColorTextMuted">#86868B</Color>
    <!-- Приглушенный -->
    <Color x:Key="ColorTextInverse">#FFFFFF</Color>
    <!-- Текст на синих кнопках -->

    <!-- Границы -->
    <Color x:Key="ColorBorder">#D2D2D7</Color>

    <!-- Состояния (чуть более глубокие цвета для лучшей видимости на белом) -->
    <Color x:Key="ColorSuccess">#28A745</Color>
    <Color x:Key="ColorWarning">#F57C00</Color>
    <Color x:Key="ColorError">#D32F2F</Color>
    <Color x:Key="ColorInfo">#0288D1</Color>

    <Color x:Key="WarningFront">#F44336</Color>
    <Color x:Key="WarningBack">#FFF0EF</Color>

    <!-- КИСТИ -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{DynamicResource ColorPrimaryPressed}" />

    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource ColorSecondary}" />
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="{DynamicResource ColorSecondaryHover}" />
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="{DynamicResource ColorSecondaryPressed}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource ColorAccent}" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource ColorBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource ColorSurface}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource ColorAltSurface}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource ColorTextMuted}" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="{DynamicResource ColorTextInverse}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource ColorBorder}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{DynamicResource ColorSecondaryHover}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{DynamicResource ColorSecondaryHover}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource ColorSuccess}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource ColorWarning}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ColorError}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource ColorInfo}" />

    <SolidColorBrush x:Key="WarningFrontBrush" Color="{DynamicResource WarningFront}" />
    <SolidColorBrush x:Key="WarningBackBrush" Color="{DynamicResource WarningBack}" />

    <!-- Прозрачные кисти -->
    <SolidColorBrush x:Key="TransparentBrush" Color="#00000000" />
    <SolidColorBrush x:Key="ShadowBrush" Color="#1A000000" />
</ResourceDictionary>