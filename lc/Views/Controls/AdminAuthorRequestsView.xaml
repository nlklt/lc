<UserControl x:Class="lc.Views.Controls.AdminAuthorRequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:lc.Views.Controls" 
             xmlns:viewmodels="clr-namespace:lc.ViewModels" 
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:AdminAuthorRequestsViewModel}">
    
    <Grid Background="{DynamicResource BackgroundBrush}" Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="8"
            Padding="12"
            Margin="4,4,0,4">

            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Заявки на авторство"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                    <Button Grid.Column="1"
                        Content="Обновить"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}" />
                </Grid>

                <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10" />

                <ListBox ItemsSource="{Binding Requests}"
                     SelectedItem="{Binding SelectedRequest, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="0,8,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding User.UserName}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />

                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />

                                    <TextBlock Text="{Binding Status}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0" />

                                    <TextBlock Text="{Binding Message}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,4,0,0"
                                           MaxHeight="80" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="8"
            Padding="12"
            Margin="4">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Детали заявки"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,12" />

                <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Background="{DynamicResource BackgroundBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedRequestUserName}"
           FontSize="16"
           FontWeight="SemiBold"
           Foreground="{DynamicResource TextPrimaryBrush}" />

                                <TextBlock Text="{Binding SelectedRequestMessage}"
           TextWrapping="Wrap"
           Margin="0,8,0,0"
           Foreground="{DynamicResource TextPrimaryBrush}" />

                                <TextBlock Text="{Binding SelectedRequestCreatedAtText}"
           Margin="0,8,0,0"
           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <TextBlock Text="{Binding SelectedRequestReviewedAtText}"
           Margin="0,4,0,0"
           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <TextBlock Text="{Binding SelectedRequestReviewerText}"
           Margin="0,4,0,0"
           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <TextBlock Text="{Binding SelectedRequestReviewCommentText}"
           Margin="0,4,0,0"
           Foreground="{DynamicResource TextSecondaryBrush}"
           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Комментарий администратора"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8" />

                        <TextBox Text="{Binding ReviewComment, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinLines="4"
                             MaxLength="2000"
                             Style="{DynamicResource TextBoxPlaceholderStyle}"
                             Tag="Комментарий к решению" />

                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <Button Content="Одобрить"
                                Command="{Binding ApproveCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Margin="0,0,8,0" />

                            <Button Content="Отклонить"
                                Command="{Binding RejectCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Foreground="{DynamicResource WarningFrontBrush}"
                                BorderBrush="{DynamicResource WarningFrontBrush}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
