<UserControl x:Class="lc.Views.Controls.MainFiltersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:lc.Views.Controls"
             xmlns:vm="clr-namespace:lc.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:CatalogViewModel}"
             mc:Ignorable="d">

    <Border Background="{DynamicResource SurfaceBrush}"
            CornerRadius="8" 
            Padding="12">

        <Border.RenderTransform>
            <TranslateTransform X="100"/>
        </Border.RenderTransform>

        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.3" />
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                     From="40" To="0"
                                     Duration="0:0:0.3" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentControl Content="{Binding}" FontSize="16">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border Padding="6,4" Margin="0,0,0,4" CornerRadius="4">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding ToggleCategoriesCommand}"/>
                                            </Border.InputBindings>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource SecondaryHoverBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <TextBlock Text="Категории"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding CategoriesSummaryText}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                        <Border Padding="6,4" Margin="0,0,0,4" CornerRadius="4">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding ToggleTagsCommand}"/>
                                            </Border.InputBindings>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource SecondaryHoverBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <TextBlock Text="Теги"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding TagsSummaryText}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="Рейтинг" Margin="8,8,8,4"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Grid Margin="8,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"  Style="{DynamicResource TextBoxPlaceholderStyle}" Tag="От"
                                                     Text="{Binding Rating.From, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                            <TextBlock Grid.Column="1" Text=" — " FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                       Foreground="{DynamicResource BorderBrush}"/>
                                            <TextBox Grid.Column="2" Style="{DynamicResource TextBoxPlaceholderStyle}" Tag="До"
                                                     Text="{Binding Rating.To, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </Grid>

                                        <TextBlock Text="Количество глав" Margin="8,8,8,4"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Grid Margin="8,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"  Style="{DynamicResource TextBoxPlaceholderStyle}" Tag="От"
                                                     Text="{Binding Chapters.From, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                            <TextBlock Grid.Column="1" Text=" — " FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                       Foreground="{DynamicResource BorderBrush}"/>
                                            <TextBox Grid.Column="2" Style="{DynamicResource TextBoxPlaceholderStyle}" Tag="До"
                                                     Text="{Binding Chapters.To, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </Grid>

                                        <TextBlock Text="Количество символов" Margin="8,8,8,4"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Grid Margin="8,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"  Style="{DynamicResource TextBoxPlaceholderStyle}" Tag="От"
                                                     Text="{Binding Symbols.From, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                            <TextBlock Grid.Column="1" Text=" — " FontWeight="Bold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                       Foreground="{DynamicResource BorderBrush}"/>
                                            <TextBox Grid.Column="2" Style="{DynamicResource TextBoxPlaceholderStyle}" Tag="До"
                                                     Text="{Binding Symbols.To, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </Grid>

                                        <TextBlock Text="Дата публикации" Style="{DynamicResource FilterLabelStyle}" />

                                        <StackPanel Orientation="Horizontal" Margin="8,2">
                                            <DatePicker SelectedDate="{Binding CreatedAt.From, Mode=TwoWay}"
                                                        Tag="С даты"
                                                        Style="{DynamicResource DatePickerPlaceholderStyle}" />

                                            <TextBlock Text=" — " VerticalAlignment="Center" />

                                            <DatePicker SelectedDate="{Binding CreatedAt.To, Mode=TwoWay}"
                                                        Tag="По дату"
                                                        Style="{DynamicResource DatePickerPlaceholderStyle}" />
                                        </StackPanel>

                                        <TextBlock Text="Статус Тайтла" Margin="8,8,8,4"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <ItemsControl ItemsSource="{Binding WritingStatusOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              Style="{DynamicResource CheckBoxThreeStateStyle}"
                                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                                              IsThreeState="True"
                                                              IsChecked="{Binding State, Mode=TwoWay,
                                                              Converter={StaticResource CheckBoxStateToNullableBoolConverter}}"
                                                              Margin="8,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Язык тайтла" Margin="8,8,8,4"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <ItemsControl ItemsSource="{Binding LanguageOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              Style="{DynamicResource CheckBoxThreeStateStyle}"
                                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                                              IsThreeState="True"
                                                              IsChecked="{Binding State, Mode=TwoWay,
                                                              Converter={StaticResource CheckBoxStateToNullableBoolConverter}}"
                                                              Margin="8,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>


                                        <TextBlock Text="Возрастной рейтинг" Margin="8,8,8,4"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <ItemsControl ItemsSource="{Binding AgeRatingOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              Style="{DynamicResource CheckBoxThreeStateStyle}"
                                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                                              IsThreeState="True"
                                                              IsChecked="{Binding State, Mode=TwoWay,
                                                              Converter={StaticResource CheckBoxStateToNullableBoolConverter}}"
                                                              Margin="8,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid Margin="0,8,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Style="{DynamicResource PrimaryButtonStyle}"
                                                    Command="{Binding ApplyFiltersCommand}"
                                                    Content="Применить" Margin="0,0,12,0"/>
                                            <Button Grid.Column="1" Style="{DynamicResource SecondaryButtonStyle}"
                                                    Command="{Binding ResetFiltersCommand}"
                                                    Content="Сбросить всё" />
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="Undo" Margin="0,0,12,0"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Command="{Binding UndoCommand}" />
                                            <Button Grid.Column="1" Content="Redo" 
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Command="{Binding RedoCommand}" />
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </ScrollViewer>
    </Border>
</UserControl>
