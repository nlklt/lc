<UserControl x:Class="lc.Views.Controls.NavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:lc.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:NavigationViewModel}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderThickness="0" 
            CornerRadius="8"
            Margin="4,4,0,4" 
            Padding="12">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Visibility="{Binding IsGuest, Converter={StaticResource BoolToVisibilityConverter}}">
                
                <TextBlock Text="LibCloud"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                <TextBlock Text="Электронная библиотека"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                
                <Separator Style="{DynamicResource SeparatorStyle}"  
                           Margin="0,12,0,0"/>
                
            </StackPanel>

            <Grid Grid.Row="0" 
                  Margin="0,0,0,8" 
                  Cursor="Hand"
                  Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">

                <Grid.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateProfileCommand}" />
                </Grid.InputBindings>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Аватарка -->
                <Border Grid.Column="0" Grid.Row="0"
                        Height="45" 
                        Width="45" 
                        CornerRadius="25" 
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    
                        <Border.Style>
                            <Style TargetType="Border">
                                
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <ImageBrush ImageSource="{Binding AvatarPath}" Stretch="UniformToFill"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                                
                            </Style>
                        </Border.Style>
                    
                    <Grid>
                        <TextBlock Text="👀" 
                                   Foreground="{DynamicResource TextInverseBrush}"
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center" 
                                   FontSize="23">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                    
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Имя и Роль -->
                <StackPanel Grid.Column="1" Grid.Row="0" 
                            VerticalAlignment="Center">
                    
                    <TextBlock Text="{Binding CurrentUserName}"
                               FontSize="16"  
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" 
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="{Binding CurrentUserRole}" 
                               FontSize="12"  
                               Opacity="0.6" 
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <Separator Grid.Row="1" Grid.ColumnSpan="2" 
                           Margin="0,12,0,0" 
                           Style="{DynamicResource SeparatorStyle}"/>
            </Grid>

            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          BorderThickness="0">

                <StackPanel>

                    <!--<Button Style="{DynamicResource NavButtonStyle}"
                        Command="{Binding LogoutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text=" :3 " Style="{DynamicResource IconTextStyle}" />
                            <TextBlock Text="Бокавая панель" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>-->

                    <TextBlock Text="ОСНОВНОЕ" 
                               Style="{DynamicResource SectionTextStyle}" />

                    <!-- Гость -->
                    <Button Style="{DynamicResource NavButtonStyle}"
                            Command="{Binding NavigateLoginCommand}"
                            Visibility="{Binding IsGuest, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👇" Style="{DynamicResource IconTextStyle}" />
                            <TextBlock Text="Войти" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource NavButtonStyle}"
                            Command="{Binding NavigateRegisterCommand}"
                            Visibility="{Binding IsGuest, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤘" Style="{DynamicResource IconTextStyle}" />
                            <TextBlock Text="Зарегистрироваться" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Основное -->
                    <Button Style="{DynamicResource NavButtonStyle}"
                            Command="{Binding NavigateCatalogCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📚" Style="{DynamicResource IconTextStyle}" />
                            <TextBlock Text="Каталог" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource NavButtonStyle}"
                            Command="{Binding RandomBookCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎲" Style="{DynamicResource IconTextStyle}" />
                            <TextBlock Text="Рандомная книга" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Писатель -->
                    <StackPanel Visibility="{Binding IsWriter, Converter={StaticResource BoolToVisibilityConverter}}">

                        <TextBlock Text="РАБОТА С КНИГАМИ" 
                                   Style="{DynamicResource SectionTextStyle}" />

                        <Button Command="{Binding NavigateCreateBookCommand}"
                                Style="{DynamicResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✍️" Style="{DynamicResource IconTextStyle}" />
                                <TextBlock Text="Создать книгу" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Style="{DynamicResource NavButtonStyle}"
                                Command="{Binding NavigateMyBooksCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Style="{DynamicResource IconTextStyle}" />
                                <TextBlock Text="Мои книги" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Админ -->
                    <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="АДМИНИСТРИРОВАНИЕ" 
                                   Style="{DynamicResource SectionTextStyle}" />

                        <Button Style="{DynamicResource NavButtonStyle}"
                                Command="{Binding NavigateAdminUsersViewCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="☷" Style="{DynamicResource IconTextStyle}"/>
                                <TextBlock Text="Таблица пользователей" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Выход -->
            <StackPanel Grid.Row="2">
                <Button Style="{DynamicResource NavButtonStyle}"
                        Command="{Binding NavigateSettingsCommand}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" Style="{DynamicResource IconTextStyle}" />
                        <TextBlock Text="Настройки" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>