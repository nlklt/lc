<UserControl x:Class="lc.Views.Controls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:lc.Views.Controls"
             xmlns:vm="clr-namespace:lc.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ProfileViewModel}"
             mc:Ignorable="d" d:DesignWidth="686.753" d:DesignHeight="456.7">

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Аватар + ID + Имя + Роль + Дата регистрации -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource SurfaceBrush}" 
                        CornerRadius="8" Padding="12" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Grid.Column="0" Grid.Row="0"
                                Width="150" Height="150" 
                                CornerRadius="75" 
                                Margin="8,0"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">

                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="{Binding AvatarPath}" 
                            Stretch="UniformToFill"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding AvatarPath}" 
                         Value="{x:Null}">
                                            <Setter Property="Background"
                        Value="{DynamicResource SurfaceAltBrush}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding AvatarPath}"
                         Value="">
                                            <Setter Property="Background"
                        Value="{DynamicResource SurfaceAltBrush}"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <TextBlock Text="👀" 
                                           Foreground="{DynamicResource TextInverseBrush}"
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" 
                                           FontSize="78">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding UserName}" 
                                       Margin="0,4,0,0" FontWeight="SemiBold"
                                       Style="{DynamicResource BaseTextBlockStyle}"
                                       FontSize="20" HorizontalAlignment="Center"/>

                            <Button Grid.Row="1" Grid.Column="0" Content="Удалить фото" 
                                    Command="{Binding ClearAvatarCommand}"
                                    Margin="0,16,8,8" Style="{DynamicResource SecondaryButtonStyle}"/>

                            <Button Grid.Row="1" Grid.Column="1" Content="🖊️"  
                                    Command="{Binding ChangeAvatarCommand}"
                                    Margin="0,16,0,8" Style="{DynamicResource SecondaryButtonStyle}"/>
                        </Grid>

                        <Separator Style="{DynamicResource SeparatorStyle}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                            <TextBlock Text="ID:" FontSize="14" Margin="0,0,8,0"
                                       Style="{DynamicResource SectionTextStyle}"/>
                            <TextBlock Text="{Binding CurrentUser.UserId}" FontSize="14"
                                       Style="{DynamicResource BaseTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"  Margin="0,8,0,10">
                            <TextBlock Text="Роль:" FontSize="14" Margin="0,0,8,0"
                                       Style="{DynamicResource SectionTextStyle}"/>
                            <TextBlock Text="{Binding Role}"
                                       Style="{DynamicResource BaseTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Дата регистрации:" FontSize="14" Margin="0,0,0,4"
                                       Style="{DynamicResource SectionTextStyle}"/>

                            <TextBlock Text="{Binding CreatedAt}"
                                    Style="{DynamicResource BaseTextBlockStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Основная информация -->
                <Border  Grid.Column="1"  Background="{DynamicResource SurfaceBrush}" 
                         CornerRadius="8" Padding="12" Margin="4,0,0,0" 
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ЛИЧНЫЕ ДАННЫЕ И НАСТРОЙКИ ИНТЕРФЕЙСА" 
                                       Style="{DynamicResource SectionTextStyle}" Margin="0,0,0,16"/>

                            <Button Grid.Column="1" Content="Назад" 
                                    Command="{Binding GoBackCommand}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,0,8"/>
                        </Grid>

                        <TextBlock Text="Имя пользователя" Margin="0,0,0,8"
                                   Style="{DynamicResource BaseTextBlockStyle}"/>
                        <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource TextBoxPlaceholderStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Язык приложения" Margin="0,0,0,8"
                                   Style="{DynamicResource BaseTextBlockStyle}"/>
                        <ComboBox ItemsSource="{Binding AllLanguages}" 
                                    SelectedItem="{Binding PreferredLanguage}"
                                    Style="{DynamicResource ComboBoxBaseStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Тема оформления" Margin="0,0,0,8"
                                   Style="{DynamicResource BaseTextBlockStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableThemes}" 
                                    SelectedItem="{Binding PreferredTheme}"
                                    Style="{DynamicResource ComboBoxBaseStyle}" Margin="0,0,0,16"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="Tomato"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <Button Content="Сохранить изменения"
                                Command="{Binding SaveSettingsCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Margin="0,0,0,16"
                                IsEnabled="{Binding CanSave}" />
                        
                        <Button  Content="Выйти из аккаунта" 
                                 Command="{Binding LogoutCommand}"
                                 Style="{DynamicResource SecondaryButtonStyle}"
                                 Foreground="{DynamicResource WarningFrontBrush}" 
                                 BorderBrush="{DynamicResource WarningFrontBrush}" Margin="0,0,0,8"/>
                        
                        <Button  Content="Удалить аккаунт" 
                                 Command="{Binding DeleteAccountCommand}"
                                 Style="{DynamicResource SecondaryButtonStyle}"
                                 Foreground="{DynamicResource WarningFrontBrush}" 
                                 BorderBrush="{DynamicResource WarningFrontBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
