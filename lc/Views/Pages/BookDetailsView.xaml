<UserControl x:Class="lc.Views.Pages.BookDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:lc.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BookDetailsViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer Padding="4"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <Border Grid.Row="0"
                            Width="290" Height="435" 
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">

                                <Setter Property="Background">
                                    <Setter.Value>
                                        <ImageBrush ImageSource="{Binding CoverPath}" Stretch="UniformToFill"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding CoverPath}" Value="">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <TextBlock Text="Обложки нету" 
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"
                                       FontSize="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Button Content="Написать главу" Margin="0,4,0,8"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Command="{Binding AddChapterCommand}"
                            Visibility="{Binding CanAddChapter, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,4,0,4">
                        <StackPanel>
                            <Button Content="{Binding LibraryButtonText}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding ToggleLibraryCommand}"
                                    Margin="0,0,0,4"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Button Content="{Binding ReadButtonText}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Command="{Binding StartReadingCommand}"
                                    IsEnabled="{Binding CanRead}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding AuthorName}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PublisherName}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Style="{DynamicResource ChipStyle}">
                                    <TextBlock Text="{Binding RatingText}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{DynamicResource ChipStyle}">
                                    <TextBlock Text="{Binding ViewsText}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{DynamicResource ChipStyle}"
                                        Background="{DynamicResource WarningBackBrush}"
                                        BorderBrush="{DynamicResource WarningFrontBrush}">
                                    <TextBlock Text="{Binding AgeRatingText}" Foreground="{DynamicResource WarningFrontBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Информация"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="{Binding BookStatusOrLangField}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding BookStatusOrLangText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Состояние" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding WritingStatusText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Создана" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding CreatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Обновлено" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding UpdatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Глав" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ChaptersCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Символов" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding SymbolsCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>
                            </UniformGrid>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0"
                                        Content="Редактировать"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Command="{Binding EditBookCommand}"
                                        Margin="0,0,4,4"
                                        Visibility="{Binding CanEditBook, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Button Grid.Row="0" Grid.Column="1"
                                        Content="{Binding ArchiveButtonText}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Command="{Binding ToggleArchiveCommand}"
                                        Margin="4,0,0,4"
                                        BorderBrush="{DynamicResource WarningFrontBrush}"
                                        Foreground="{DynamicResource WarningFrontBrush}"
                                        Background="{DynamicResource WarningBackBrush}"
                                        Visibility="{Binding CanToggleArchiveBook, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                        Content="Удалить"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Command="{Binding DeleteBookCommand}"
                                        Margin="0,8,0,0"
                                        BorderBrush="{DynamicResource WarningFrontBrush}"
                                        Foreground="{DynamicResource WarningFrontBrush}"
                                        Background="{DynamicResource WarningBackBrush}"
                                        Visibility="{Binding CanDeleteBook, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   Margin="8,4,0,0"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <!--<Button Grid.Column="1"
                                Content="Назад"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Command="{Binding BackCommand}"/>-->
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4" VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{DynamicResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{DynamicResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{DynamicResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Описание"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding Description}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Главы"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Chapters}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Chapters.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <TextBlock Text="Список глав пока пуст..."
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       FontStyle="Italic"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                Padding="0,8,0,8"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Chapter.ChapterNumber, StringFormat=Глава {0}}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Chapter.Title}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Chapter.Status}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Button Content="Открыть"
                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.OpenChapterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,0,4,0"
                                                            Visibility="{Binding CanOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                    <Button Content="Редактировать"
                                                            Command="{Binding DataContext.EditChapterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                    <Button Content="Удалить"
                                                            Command="{Binding DataContext.DeleteChapterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}">
                        <StackPanel>
                            <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Написать комментарий"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <TextBox Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource TextBoxPlaceholderStyle}"
                                             TextWrapping="Wrap"/>

                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Style="{DynamicResource PrimaryButtonStyle}"
                                                Content="Отправить"
                                                Command="{Binding AddCommentCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Comments}" Margin="0,10,0,0">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Comments.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <TextBlock Text="Комментариев пока нет..."
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       FontStyle="Italic"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,4,0,8"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="{Binding User.UserName}"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               FontSize="11"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Text}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>