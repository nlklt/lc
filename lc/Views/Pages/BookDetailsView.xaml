<UserControl x:Class="lc.Views.Pages.BookDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:lc.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BookDetailsViewModel}"
             d:DesignWidth="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer Padding="4"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled" Cursor="Hand">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Margin="4,4,8,4" Width="290" Height="435" CornerRadius="6">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding CoverImage}" Stretch="UniformToFill"
                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border.Background>
                    </Border>

                    <StackPanel Orientation="Vertical" Margin="0,0,8,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Добавить в список"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding ToggleLibraryCommand}" Margin="0,0,4,4"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Button Grid.Column="1" Content="❤"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding ToggleFavoriteCommand}" Margin="0,0,0,4"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>

                        <Button Content="Читать" Style="{DynamicResource PrimaryButtonStyle}"
                                Command="{Binding StartReadingCommand}" 
                                IsEnabled="{Binding CanRead}"/>
                    </StackPanel>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="20" FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding AuthorName}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PublisherName}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Style="{DynamicResource ChipStyle}">
                                    <TextBlock Text="{Binding RatingText}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{DynamicResource ChipStyle}">
                                    <TextBlock Text="{Binding ViewsText}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{DynamicResource ChipStyle}"
                                        Background="{DynamicResource WarningBackBrush}" BorderBrush="{DynamicResource WarningFrontBrush}">
                                    <TextBlock Text="{Binding AgeRatingText}" Foreground="{DynamicResource WarningFrontBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="Информация" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Статус" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding WritingStatusText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Публикация" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding CreatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Обновлено" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding UpdatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Язык" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding LanguageText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Глав" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ChaptersCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Символов" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding SymbolsCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>
                            </UniformGrid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Редактировать"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding EditBookCommand}" Margin="0,0,4,4"
                                    Visibility="{Binding CanEditOrDelete, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Button Grid.Column="1" Content="В архив" Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteBookCommand}" Margin="4,0,0,4"
                                    BorderBrush="{DynamicResource WarningFrontBrush}" Background="{DynamicResource WarningBackBrush}"
                                    Visibility="{Binding CanEditOrDelete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Title}" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"/>

                        <Grid Grid.Column="1" Height="28" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0" Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Оценить:" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Content="1" Style="{DynamicResource SecondaryButtonStyle}" Command="{Binding RateBookCommand}" CommandParameter="1" Padding="8,2" Margin="2,0"/>
                                <Button Content="2" Style="{DynamicResource SecondaryButtonStyle}" Command="{Binding RateBookCommand}" CommandParameter="2" Padding="8,2" Margin="2,0"/>
                                <Button Content="3" Style="{DynamicResource SecondaryButtonStyle}" Command="{Binding RateBookCommand}" CommandParameter="3" Padding="8,2" Margin="2,0"/>
                                <Button Content="4" Style="{DynamicResource SecondaryButtonStyle}" Command="{Binding RateBookCommand}" CommandParameter="4" Padding="8,2" Margin="2,0"/>
                                <Button Content="5" Style="{DynamicResource SecondaryButtonStyle}" Command="{Binding RateBookCommand}" CommandParameter="5" Padding="8,2" Margin="2,0"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="Назад"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Command="{Binding BackCommand}"/>
                        </Grid>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4" VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{DynamicResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{DynamicResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{DynamicResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Описание" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding Description}" FontSize="14" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Главы" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding Chapters}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Chapters.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <TextBlock Text="Список глав пока пуст..." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{DynamicResource SecondaryButtonStyle}" 
                                                Content="{Binding Title}" 
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Margin="0,0,0,4"
                                                Command="{Binding DataContext.OpenChapterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Написать комментарий" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                    <TextBox Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{DynamicResource TextBoxPlaceholderStyle}"
                                             Tag="Отличная книга!!!"
                                             TextWrapping="Wrap" MinLines="2"/>

                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,8">
                                        <Button Style="{DynamicResource PrimaryButtonStyle}"
                                Content="Отправить"
                                Command="{Binding AddCommentCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Comments}" Margin="0,10,0,0">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Comments.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <TextBlock Text="Комментариев пока нет..." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,4,0,8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="{Binding UserName}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>