<UserControl x:Class="lc.Views.Pages.BookDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:lc.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BookDetailsViewModel}" 
             d:DesignWidth="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
        </Style>

        <Style x:Key="ChipStyleAge" TargetType="Border" BasedOn="{StaticResource ChipStyle}">
            <Setter Property="BorderBrush" Value="#DE7072"/>
            <Setter Property="Background" Value="#2C2323"/>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer Margin="4"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка -->
                <StackPanel Grid.Column="0">

                    <Border Margin="4,4,8,4" Width="290" Height="435" CornerRadius="6">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding CoverImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border.Background>
                    </Border>

                    <StackPanel Orientation="Vertical" Margin="0,0,8,4" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Добавить в библиотеку"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding AddToLibraryCommand}"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding CanAddToLibrary, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Button Grid.Column="1" Content="❤"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>

                        <Button Content="Читать"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding StartReadingCommand}"
                                IsEnabled="{Binding CanRead}"/>
                    </StackPanel>

                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding AuthorName}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PublisherName}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Style="{StaticResource ChipStyle}">
                                    <TextBlock Text="{Binding RatingText}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{StaticResource ChipStyle}">
                                    <TextBlock Text="{Binding ViewsText}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Style="{StaticResource ChipStyleAge}">
                                    <TextBlock Text="{Binding AgeRatingText}" Foreground="#DE7072"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,8,4" Height="140">
                        <StackPanel>
                            <TextBlock Text="Информация"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <UniformGrid Height="Auto">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Статус" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding WritingStatusText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Публикация" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding CreatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,2"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Обновлено" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding UpdatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,2"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Язык" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding LanguageText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,2"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Глав" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ChaptersCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,2"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Символов" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding SymbolsCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,2"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Правая колонка -->
                <StackPanel Grid.Column="1">

                    <Grid Margin="0,8,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Title}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Оценить"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Background="{DynamicResource SecondaryHoverBrush}"
                                    Foreground="{DynamicResource TextInverseBrush}"
                                    Command="{Binding BackCommand}" Margin="8,0"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Content="Назад"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BackCommand}" Margin="0,0,4,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Описание"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding Description}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="Главы"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Список глав пока пуст..." 
                                       Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,4">
                        <StackPanel>
                            <Grid Visibility="{Binding CanAddToLibrary, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Написать комментарии"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <TextBox Style="{DynamicResource TextBoxPlaceholderStyle}"
                                             Tag="Отличная книга!!!"/>
                                    <StackPanel HorizontalAlignment="Right" 
                                                Orientation="Horizontal" Margin="0,8">
                                        <Button Style="{DynamicResource SecondaryButtonStyle}"
                                                Content="Отмена" Margin="8,0"/>
                                        <Button Style="{DynamicResource PrimaryButtonStyle}"
                                                Content="Отправить"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Комментариев пока нет..." 
                                           Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>