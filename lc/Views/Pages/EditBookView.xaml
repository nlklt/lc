<UserControl x:Class="lc.Views.Pages.EditBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:lc.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EditBookViewModel}">

    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="MutedValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled" VerticalAlignment="Top"
                      Margin="4">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="12" Height="Auto">

                <StackPanel>
                    <Border Width="290"
                            Height="435"
                            CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <ImageBrush ImageSource="{Binding CoverPath}"
                                                    Stretch="UniformToFill"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                        <Setter Property="Background"
                                                Value="{DynamicResource SurfaceAltBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CoverPath}" Value="">
                                        <Setter Property="Background"
                                                Value="{DynamicResource SurfaceAltBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Выбрать обложку"
                                Command="{Binding ChooseCoverCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,0,4,0"/>

                        <Button Grid.Column="1"
                                Content="Очистить"
                                Command="{Binding ClearCoverCommand}"
                                Foreground="{DynamicResource WarningFrontBrush}"
                                Background="{DynamicResource WarningBackBrush}"
                                BorderBrush="{DynamicResource WarningFrontBrush}"
                                Style="{DynamicResource SecondaryButtonStyle}"/>
                    </Grid>

                    <Border Background="{DynamicResource BackgroundBrush}"
                            CornerRadius="8"
                            Padding="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">

                        <StackPanel>
                            <TextBlock Text="Информация"
                                       Style="{DynamicResource SectionTitle}"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Статус" Style="{StaticResource MutedValue}"/>
                                    <TextBlock Text="{Binding BookStatusText}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Язык" Style="{StaticResource MutedValue}"/>
                                    <TextBlock Text="{Binding LanguageText}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Создана" Style="{StaticResource MutedValue}"/>
                                    <TextBlock Text="{Binding CreatedAtText}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Обновлена" Style="{StaticResource MutedValue}"/>
                                    <TextBlock Text="{Binding UpdatedAtText}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Символов" Style="{StaticResource MutedValue}"/>
                                    <TextBlock Text="{Binding SymbolsCount}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Глав" Style="{StaticResource MutedValue}"/>
                                    <TextBlock Text="{Binding ChaptersCount}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Top"
                      HorizontalScrollBarVisibility="Disabled" Margin="0,4,4,4">
            <Border Grid.Column="1" Height="Auto"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="12">

                <StackPanel>
                    <TextBlock Text="{Binding HeaderText}"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <TextBlock Text="Название" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPlaceholderStyle}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Автор" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPlaceholderStyle}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxPlaceholderStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Hidden"
                             Height="175"/>

                    <TextBlock Text="Статус написания" Style="{StaticResource FieldLabel}" Margin="0,16,0,4"/>
                    <ComboBox ItemsSource="{Binding WritingStatuses}"
                              Style="{DynamicResource ComboBoxBaseStyle}"
                              SelectedItem="{Binding SelectedWritingStatus, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="Язык" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Languages}"
                              Style="{DynamicResource ComboBoxBaseStyle}"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="Возрастной рейтинг" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding AgeRatings}"
                              Style="{DynamicResource ComboBoxBaseStyle}"
                              SelectedItem="{Binding SelectedAgeRating, Mode=TwoWay}"
                              Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="4"
                                Padding="6"
                                Margin="0,0,4,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">

                            <DockPanel>
                                <TextBlock Text="Категории"
                                           Style="{DynamicResource FieldLabel}"
                                           DockPanel.Dock="Top"
                                           Margin="0,0,0,8"/>

                                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                              MaxHeight="200"
                                              HorizontalScrollBarVisibility="Hidden">
                                    <ItemsControl ItemsSource="{Binding CategoryItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          Style="{DynamicResource CheckBoxTwoStateStyle}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Margin="0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="4"
                                Padding="6"
                                Margin="0,0,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">

                            <DockPanel>
                                <TextBlock Text="Теги"
                                           Style="{DynamicResource FieldLabel}"
                                           DockPanel.Dock="Top"
                                           Margin="0,0,0,8"/>

                                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                              MaxHeight="200"
                                              HorizontalScrollBarVisibility="Hidden">
                                    <ItemsControl ItemsSource="{Binding TagItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          Style="{DynamicResource CheckBoxTwoStateStyle}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Margin="0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="Tomato"
                               TextWrapping="Wrap"
                               Margin="0,4,0,2"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0"
                                Content="{Binding PrimaryActionText}"
                                Command="{Binding SaveCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPublishedEditMode}" Value="True">
                                            <Setter Property="Grid.ColumnSpan" Value="3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Row="0" Grid.Column="2"
                                Content="Опубликовать"
                                Command="{Binding PublishCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPublishedEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                Content="Отмена"
                                Command="{Binding CancelCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
        </Grid>
</UserControl>