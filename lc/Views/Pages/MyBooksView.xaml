<UserControl x:Class="lc.Views.Pages.MyBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:lc.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MyBooksViewModel}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Мои книги"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Books}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="190"
                                    Margin="0,0,14,14"
                                    Padding="10"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceBrush}">
                                <StackPanel>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.OpenEditBookCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Border Height="240"
                                                CornerRadius="10"
                                                Background="{DynamicResource SurfaceAltBrush}"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Image Source="{Binding CoverImagePath}"
                                                       Stretch="UniformToFill" />

                                                <Border HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="8"
                                                        Padding="8,4"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource SurfaceBrush}">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,10,0,0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.SelectBookCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Button>

                                    <TextBlock Text="{Binding ChaptersCount, StringFormat=Глав: {0}}"
                                               Margin="0,6,0,0"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="16"
                CornerRadius="14"
                Background="{DynamicResource SurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Статистика:"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Text="{Binding SelectedBookTitle}"
                               Margin="8,0,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,14,0,0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SelectedBookStats}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="78"
                                        Margin="0,0,10,0"
                                        Padding="6"
                                        CornerRadius="10"
                                        Background="{DynamicResource SurfaceAltBrush}">
                                    <StackPanel VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding DayLabel}"
                                                   HorizontalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />

                                        <Grid Height="170"
                                              Margin="0,8,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding ViewsCount}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <Border Width="12"
                                                        Height="{Binding ViewsBarHeight}"
                                                        CornerRadius="4"
                                                        Margin="0,6,0,0"
                                                        Background="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="👁️"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RatingsCount}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <Border Width="12"
                                                        Height="{Binding RatingsBarHeight}"
                                                        CornerRadius="4"
                                                        Margin="0,6,0,0"
                                                        Background="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="❤️"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding CommentsCount}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <Border Width="12"
                                                        Height="{Binding CommentsBarHeight}"
                                                        CornerRadius="4"
                                                        Margin="0,6,0,0"
                                                        Background="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="💬"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="{Binding FullDayLabel}"
                                                   TextAlignment="Center"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>