<UserControl x:Class="lc.Views.Pages.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:lc.ViewModels"
             xmlns:vc="clr-namespace:lc.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:ProfileViewModel}">

    <Grid>
        <!-- Профиль -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel Margin="4">

                <!-- Шапка -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватарка -->
                        <Border Grid.Column="0" Grid.Row="0"
                                Width="60" Height="60" 
                                CornerRadius="60" 
                                Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">

                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="{Binding AvatarPath}" 
                            Stretch="UniformToFill"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding AvatarPath}" 
                         Value="{x:Null}">
                                            <Setter Property="Background"
                        Value="{DynamicResource SurfaceAltBrush}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding AvatarPath}"
                         Value="">
                                            <Setter Property="Background"
                        Value="{DynamicResource SurfaceAltBrush}"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <TextBlock Text="👀" 
                                           Foreground="{DynamicResource TextInverseBrush}"
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" 
                                           FontSize="30">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Имя и Роль -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding UserName}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Role}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Кнопка перехода в настройки -->
                        <Button Grid.Column="2" Content="⚙ Настройки" 
                                VerticalAlignment="Top"
                                Command="{Binding ToggleSettingsCommand}" 
                                Style="{DynamicResource SecondaryButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- Продолжить чтение -->
                <TextBlock Text="Продолжить чтение" FontSize="20" 
                           FontWeight="SemiBold" Margin="12,0,12,12"
                           Style="{DynamicResource BaseTextBlockStyle}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <!-- Замените ReadingHistory на вашу коллекцию истории во ViewModel -->
                    <!--<ItemsControl ItemsSource="{Binding ReadingHistory}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>-->
                                <!-- Карточка книги -->
                    <!--<Border Width="130" Margin="0,0,20,0" Background="Transparent" Cursor="Hand">
                                    <StackPanel>
                                        <Border Height="180" CornerRadius="8" Background="{DynamicResource SurfaceAltBrush}" Margin="0,0,0,10">
                                            <Image Source="{Binding CoverImagePath}" Stretch="UniformToFill">
                                                <Image.Clip>
                                                    <RectangleGeometry Rect="0,0,130,180" RadiusX="8" RadiusY="8"/>
                                                </Image.Clip>
                                            </Image>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding LastChapter, StringFormat='Глава {0}'}" FontSize="12" Foreground="{DynamicResource SurfaceAltBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>-->
                </ScrollViewer>

                <!-- ЛИЧНЫЕ СПИСКИ КНИГ -->
                <TextBlock Text="Мои списки" FontSize="20" 
                           FontWeight="SemiBold" Margin="12"
                           Style="{DynamicResource BaseTextBlockStyle}"/>
                <!-- Замените UserLists на вашу коллекцию списков во ViewModel -->
                <!-- <ItemsControl ItemsSource="{Binding UserLists}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>-->
                            <!-- Карточка списка (например, Избранное, Прочитано) -->
                <!--<Border Width="220" Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="15" Margin="0,0,20,20" Cursor="Hand">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding BooksCount, StringFormat='0'}" FontSize="13" Foreground="{DynamicResource SurfaceAltBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>-->

            </StackPanel>
        </ScrollViewer>

        <!-- Настройки -->
        <vc:SettingsView>
            <vc:SettingsView.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </vc:SettingsView.Style>
        </vc:SettingsView>
    </Grid>
</UserControl>