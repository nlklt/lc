<UserControl x:Class="lc.Views.Pages.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:lc.ViewModels"
             xmlns:vc="clr-namespace:lc.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:ProfileViewModel}">

    <Grid>
        <!-- Профиль -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel Margin="4">

                <!-- Шапка -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватарка -->
                        <Border Grid.Column="0" Grid.Row="0"
                                Width="60" Height="60" 
                                CornerRadius="60" 
                                Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">

                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="{Binding AvatarPath}" 
                                                        Stretch="UniformToFill"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding AvatarPath}" 
                                                     Value="{x:Null}">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SurfaceAltBrush}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding AvatarPath}"
                                                     Value="">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SurfaceAltBrush}"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <TextBlock Text="👀" 
                                           Foreground="{DynamicResource TextInverseBrush}"
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" 
                                           FontSize="30">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Имя и Роль -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding UserName}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Role}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Кнопка перехода в настройки -->
                        <Button Grid.Column="2" Content="⚙ Настройки" 
                                VerticalAlignment="Top"
                                Command="{Binding ToggleSettingsCommand}" 
                                Style="{DynamicResource SecondaryButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- Продолжить чтение -->
                <TextBlock Text="Продолжить чтение" FontSize="16" 
                           FontWeight="SemiBold" Margin="4,0,12,12"
                           Style="{DynamicResource BaseTextBlockStyle}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding ContinueReadingBooks}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContinueReadingBooks.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="Продолжать чтение пока нечего..."
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               FontStyle="Italic"
                                                               Margin="4,0,0,0"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenContinueReadingCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="0,0,14,0"
                                        Cursor="Hand">
                                    <Border Width="130" Background="Transparent">
                                        <StackPanel>
                                            <Border Height="180"
                                    CornerRadius="8"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    Margin="0,0,0,10">
                                                <Image Source="{Binding CoverPath}"
                                       Stretch="UniformToFill"/>
                                            </Border>

                                            <TextBlock Text="{Binding Title}"
                                       FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,4"/>

                                            <TextBlock Text="{Binding LastChapterText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,2"/>

                                            <TextBlock Text="{Binding ReadingProgressPercent, StringFormat=Прогресс: {0}%}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>

                                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Value="{Binding ReadingProgressPercent}"
                                         Height="6"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ЛИЧНЫЕ СПИСКИ КНИГ -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="4">
                    <StackPanel Orientation="Horizontal">

                        <ItemsControl ItemsSource="{Binding UserLibraryLists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectListCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,0,10,0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="BtnBorder" 
                                                                    CornerRadius="4"
                                                                    Padding="5,4"
                                                                    Background="{DynamicResource SurfaceBrush}">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.6"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="➕" 
                                FontSize="12"
                                Cursor="Hand"
                                Padding="4,4"
                                Command="{Binding CreateListCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- СПИСОК -->
                <ItemsControl ItemsSource="{Binding SelectedListBooks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,0,4,4"
                                    Padding="4"
                                    CornerRadius="6"
                                    Background="{DynamicResource SurfaceBrush}">
                                <StackPanel>
                                    <Border Height="236"
                                            Width="160"
                                            CornerRadius="6"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            Margin="0,0,0,4">
                                        <Image Source="{Binding CoverPath}"
                                               Stretch="UniformToFill"/>
                                    </Border>

                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,2"/>

                                    <TextBlock Text="{Binding ReadingProgressPercent, StringFormat=Прогресс: {0}%}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,2"/>

                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ReadingProgressPercent}"
                                                 Height="6"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- Настройки -->
        <vc:SettingsView>
            <vc:SettingsView.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </vc:SettingsView.Style>
        </vc:SettingsView>
    </Grid>
</UserControl>