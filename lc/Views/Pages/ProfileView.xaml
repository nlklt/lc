<UserControl x:Class="lc.Views.Pages.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:lc.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1000"
             Background="#121212"
             d:DataContext="{d:DesignInstance vm:ProfileViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" MaxWidth="800" HorizontalAlignment="Left">

            <!-- Заголовок страницы -->
            <TextBlock Text="Настройки профиля" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка: Аватар -->
                <Border Grid.Column="0" 
                        Background="#1E1E1E" 
                        CornerRadius="12" 
                        Padding="20" 
                        VerticalAlignment="Top">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="150" Height="150" CornerRadius="75" Background="#2A2A2A">
                            <Border.OpacityMask>
                                <VisualBrush>
                                    <VisualBrush.Visual>
                                        <Ellipse Width="150" Height="150" Fill="Black"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Border.OpacityMask>
                            <Image Source="{Binding AvatarPath, TargetNullValue='/Resources/Images/default_avatar.png'}" 
                                   Stretch="UniformToFill"/>
                        </Border>

                        <Button Content="Изменить фото" 
                                Command="{Binding ChangeAvatarCommand}"
                                Margin="0,15,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="140"/>
                    </StackPanel>
                </Border>

                <!-- Правая колонка: Данные и настройки -->
                <StackPanel Grid.Column="1" Margin="25,0,0,0">

                    <!-- Основная информация -->
                    <Border Background="#1E1E1E" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="ЛИЧНЫЕ ДАННЫЕ" FontSize="12" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,15"/>

                            <TextBlock Text="Имя пользователя" Foreground="#CCC" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource TextBoxPlaceholderStyle}"  
                                     Margin="0,0,0,20"/>

                            <TextBlock Text="Роль" Foreground="#CCC" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentUser.Role}" 
                                       Foreground="White" 
                                       FontSize="16" 
                                       Margin="0,0,0,20"/>

                            <TextBlock Text="Дата регистрации" Foreground="#CCC" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentUser.CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" 
                                       Foreground="White" 
                                       FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <!-- Предпочтения интерфейса -->
                    <Border Background="#1E1E1E" CornerRadius="12" Padding="25">
                        <StackPanel>
                            <TextBlock Text="ИНТЕРФЕЙС" FontSize="12" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Язык приложения" Foreground="#CCC" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding AllLanguages}" 
                                              SelectedItem="{Binding SelectedLanguage}"
                                              Style="{StaticResource ComboBoxLabeledStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Тема оформления" Foreground="#CCC" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding AvailableThemes}" 
                                              SelectedItem="{Binding SelectedTheme}"
                                              Style="{StaticResource ComboBoxLabeledStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Button Content="Сохранить изменения" 
                                    Command="{Binding SaveSettingsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Width="200" Height="40"/>
                        </StackPanel>
                    </Border>

                    <!-- Опасная зона -->
                    <Button Content="Выйти из аккаунта" 
                            Command="{Binding LogoutCommand}"
                            Foreground="#FF4B4B"
                            Background="Transparent"
                            BorderBrush="#444"
                            BorderThickness="1"
                            Margin="0,30,0,0"
                            HorizontalAlignment="Left"
                            Padding="15,8"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>