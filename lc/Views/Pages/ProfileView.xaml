<UserControl x:Class="lc.Views.Pages.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:lc.ViewModels"
             xmlns:vc="clr-namespace:lc.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:ProfileViewModel}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel Margin="4">

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="60"
                                Height="60"
                                CornerRadius="60"
                                Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="{Binding AvatarPath}"
                                                        Stretch="UniformToFill" />
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SurfaceAltBrush}" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                            <Setter Property="Background"
                                                    Value="{DynamicResource SurfaceAltBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="👀"
                                       Foreground="{DynamicResource TextInverseBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="30">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUserName}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding CurrentUserRole}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CreatedAt, StringFormat=Дата регистрации: {0:dd.MM.yyyy}}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="⚙ Настройки"
                                VerticalAlignment="Top"
                                Command="{Binding ToggleSettingsCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" />
                    </Grid>
                </Border>

                <TextBlock Text="Продолжить чтение"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="4,0,12,12"
                           Style="{DynamicResource BaseTextBlockStyle}" />

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding ContinueReadingBooks}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContinueReadingBooks.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="Продолжать чтение пока нечего..."
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               FontStyle="Italic"
                                                               Margin="4,0,0,0" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenContinueReadingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,0,14,0"
                                            Cursor="Hand">
                                    <Border Width="130"
                                                Background="Transparent">
                                        <StackPanel>
                                            <Border Height="180"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource SurfaceAltBrush}"
                                                        Margin="0,0,0,10">
                                                <Image Source="{Binding CoverPath}"
                                                           Stretch="UniformToFill" />
                                            </Border>

                                            <TextBlock Text="{Binding Title}"
                                                           FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,4" />

                                            <TextBlock Text="{Binding LastChapterText}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,2" />

                                            <TextBlock Text="{Binding ReadingProgressPercent, StringFormat=Прогресс: {0}%}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />

                                            <ProgressBar Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding ReadingProgressPercent}"
                                                             Height="6" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Личные списки"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding NewListName, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="100"
                                     Style="{DynamicResource TextBoxPlaceholderStyle}"
                                     Tag="Название нового списка" />

                            <Button Grid.Column="1"
                                    Content="Создать"
                                    Command="{Binding CreateListCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Margin="8,0,0,0" />
                        </Grid>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Margin="0,0,0,10">
                            <ItemsControl ItemsSource="{Binding UserLibraryLists}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectListCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Margin="0,0,10,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="BtnBorder"
                                                                        CornerRadius="4"
                                                                        Padding="8,5"
                                                                        Background="{DynamicResource SurfaceAltBrush}">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.75" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding SelectedListName, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="100"
                                     IsEnabled="{Binding SelectedListCanBeEdited}"
                                     Style="{DynamicResource TextBoxPlaceholderStyle}"
                                     Tag="Название выбранного списка" />

                            <Button Grid.Column="1"
                                    Content="Переименовать"
                                    Command="{Binding RenameSelectedListCommand}"
                                    IsEnabled="{Binding SelectedListCanBeEdited}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0" />

                            <Button Grid.Column="2"
                                    Content="Удалить"
                                    Command="{Binding DeleteSelectedListCommand}"
                                    IsEnabled="{Binding SelectedListCanBeEdited}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Foreground="{DynamicResource WarningFrontBrush}"
                                    BorderBrush="{DynamicResource WarningFrontBrush}"
                                    Margin="8,0,0,0" />
                        </Grid>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="Tomato"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <ItemsControl ItemsSource="{Binding SelectedListBooks}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedListBooks.Count}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <TextBlock Text="В выбранном списке пока нет книг."
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontStyle="Italic" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"
                                            Width="166" 
                                            Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" 
                                                          Command="{Binding DataContext.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="249"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Обложка -->
                                            <Border Grid.Row="0"
                                                    Width="166" Height="249" 
                                                    CornerRadius="6">
                                                <Border.Style>
                                                    <Style TargetType="Border">

                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <ImageBrush ImageSource="{Binding CoverImagePath}"
                                                                            Stretch="UniformToFill"/>
                                                            </Setter.Value>
                                                        </Setter>

                                                        <Style.Triggers>

                                                            <DataTrigger Binding="{Binding CoverImagePath}" Value="{x:Null}">
                                                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding CoverImagePath}" Value="">
                                                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                            </DataTrigger>

                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <TextBlock Text="Обложки нету" 
                                                               FontStyle="Italic"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Center"
                                                               FontSize="14">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CoverImagePath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CoverImagePath}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <!-- Инфо -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="40"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Button Content="Удалить из списка"
                                                        Command="{Binding DataContext.RemoveBookFromSelectedListCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource SecondaryButtonStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <vc:AdminAuthorRequestsView 
                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsReader, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Заявка на становление автором"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="{Binding AuthorRequestStatusText}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

                        <TextBox Text="{Binding AuthorRequestMessage, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="2000"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinLines="3"
                 Style="{DynamicResource TextBoxPlaceholderStyle}"
                 Tag="Напишите, почему хотите стать автором..."
                 Visibility="{Binding IsReader, Converter={StaticResource BoolToVisibilityConverter}}"
                 Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Visibility="{Binding IsReader, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Content="Отправить заявку"
                    Command="{Binding SendAuthorRequestCommand}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Margin="0,0,8,0" />

                            <Button Content="Отменить заявку"
                    Command="{Binding CancelAuthorRequestCommand}"
                    Style="{DynamicResource SecondaryButtonStyle}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding AuthorRequests}"
                      Margin="0,12,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AuthorRequests.Count}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <TextBlock Text="История заявок пока пуста."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontStyle="Italic" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,8,0,8"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding Status}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Grid>

                                            <TextBlock Text="{Binding Message}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />

                                            <TextBlock Text="{Binding ReviewComment}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Visibility="{Binding ReviewComment, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <vc:SettingsView>
            <vc:SettingsView.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </vc:SettingsView.Style>
        </vc:SettingsView>
    </Grid>
</UserControl>