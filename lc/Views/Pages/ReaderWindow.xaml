<Window x:Class="lc.Views.Windows.ReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:lc.ViewModels"
        xmlns:vp="clr-namespace:lc.Views.Pages"
        xmlns:conv="clr-namespace:lc.Converters"
        xmlns:vc="clr-namespace:lc.Views.Controls"
        mc:Ignorable="d"
        Title="Ридер"
        Width="1100"
        Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Themes/Dark.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Brushes.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Metrics.xaml"/>

                <ResourceDictionary Source="/Resources/Controls/Text.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/Button.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/ListBox.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/ComboBox.xaml"/>
                <ResourceDictionary Source="/Resources/Controls/DatePicker.xaml"/>

                <ResourceDictionary Source="/Resources/Variants/Buttons.xaml"/>
                <ResourceDictionary Source="/Resources/Variants/Inputs.xaml"/>
                <ResourceDictionary Source="/Resources/Variants/CheckBoxes.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:NullableDoubleToStringConverter x:Key="NullableDoubleToStringConverter" />
            <conv:CheckBoxStateToNullableBoolConverter x:Key="CheckBoxStateToNullableBoolConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding BookTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12"/>

                <ListBox ItemsSource="{Binding Chapters}"
                         SelectedItem="{Binding SelectedChapter}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         DisplayMemberPath="Title"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding ChapterText}"
                           TextWrapping="Wrap"
                           LineHeight="24"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="15"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>