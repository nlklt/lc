<ContentControl x:Class="lc.Views.Pages.RegisterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:lc.Views.Pages"
      xmlns:vm="clr-namespace:lc.ViewModels"
      xmlns:vma="clr-namespace:lc.ViewModels"
      d:DataContext="{d:DesignInstance Type=vma:RegisterViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" >

    <Grid Background="{StaticResource BackgroundBrush}">

        <Border Width="360"
                Padding="24"
                CornerRadius="12"
                Background="{StaticResource BorderHoverBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Регистрация"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Имя пользователя"/>
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,12"/>

                <TextBlock Text="Пароль"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,12"/>

                <TextBlock Text="Повторите пароль"/>
                <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,20"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Tomato"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Button Content="Создать аккаунт"
                        Command="{Binding RegisterCommand}"
                        Height="36"
                        Margin="0,0,0,12"/>

                <Button Content="Уже есть аккаунт"
                        Command="{Binding NavigateLoginCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>

            </StackPanel>
        </Border>
    </Grid>
</ContentControl>
