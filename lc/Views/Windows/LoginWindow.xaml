<Window x:Class="lc.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:lc.ViewModels"
        xmlns:help="clr-namespace:lc.Helpers"
        xmlns:conv="clr-namespace:lc.Converters"
        mc:Ignorable="d"
        Title="Вход" 
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FocusManager.FocusedElement="{Binding ElementName=UserNameTb}"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      CornerRadius="0" GlassFrameThickness="0" 
                      UseAeroCaptionButtons="True" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="☁ LibCloud"  Foreground="{DynamicResource TextPrimaryBrush}" 
                           FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—"  Style="{DynamicResource CaptionButtonStyle}" Click="Minimize_Click"/>
                    <Button Content="☐" Style="{DynamicResource CaptionButtonStyle}" Click="Maximize_Click"/>
                    <Button Content="✕" Style="{DynamicResource CloseButtonStyle}"   Command="{Binding CancelCommand}"  IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"  Padding="12"
                Background="{DynamicResource SurfaceBrush}"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" Width="400">
            <StackPanel>
                <TextBlock Text="Вход" FontSize="20" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,24"/>

                <TextBlock Text="Имя пользователя" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBox x:Name="UserNameTb" Style="{DynamicResource TextBoxPlaceholderStyle}"
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
                         Tag="user" Margin="0,4,0,16" MaxLength="16"/>

                <TextBlock  x:Name="Password" Text="Пароль" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <PasswordBox x:Name="PassBox"  Style="{DynamicResource PasswordBoxPlaceholderStyle}"
                             Tag=".pth1234" Margin="0,4,0,8" MaxLength="64"/>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Tomato" 
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <Button Content="Войти" Command="{Binding LoginCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        CommandParameter="{Binding ElementName=PassBox}"
                        Height="36" Margin="0,0,0,8" IsDefault="True"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

                <Button Content="Создать аккаунт" 
                        Command="{Binding NavigateRegisterCommand}" 
                        Style="{DynamicResource SecondaryButtonStyle}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>