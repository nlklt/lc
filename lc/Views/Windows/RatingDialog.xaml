<Window x:Class="lc.Views.Windows.RatingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:lc.ViewModels" 
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        d:DataContext="{d:DesignInstance Type=vm:RatingViewModel}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="True" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="★"  Foreground="{DynamicResource TextPrimaryBrush}" 
                   FontWeight="Bold" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Title}"  Foreground="{DynamicResource TextPrimaryBrush}" 
                       FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Style="{DynamicResource CloseButtonStyle}" 
                Command="{Binding CancelCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="12,0,12,12" Background="{DynamicResource SurfaceBrush}">
            <StackPanel>
                <TextBlock Text="{Binding Message}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,10"/>

                <UniformGrid Columns="5" Margin="0,0,0,8">
                    <Button Content="★" FontSize="24" Command="{Binding SetRatingCommand}" Style="{DynamicResource SecondaryButtonStyle}" CommandParameter="1" Margin="2"/>
                    <Button Content="★" FontSize="24" Command="{Binding SetRatingCommand}" Style="{DynamicResource SecondaryButtonStyle}" CommandParameter="2" Margin="2"/>
                    <Button Content="★" FontSize="24" Command="{Binding SetRatingCommand}" Style="{DynamicResource SecondaryButtonStyle}" CommandParameter="3" Margin="2"/>
                    <Button Content="★" FontSize="24" Command="{Binding SetRatingCommand}" Style="{DynamicResource SecondaryButtonStyle}" CommandParameter="4" Margin="2"/>
                    <Button Content="★" FontSize="24" Command="{Binding SetRatingCommand}" Style="{DynamicResource SecondaryButtonStyle}" CommandParameter="5" Margin="2"/>
                </UniformGrid>

                <UniformGrid Columns="2">
                    <Button Content="Ок"
                            Command="{Binding AcceptCommand}"
                            IsDefault="True"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Height="32"
                            Margin="0,0,5,0"/>
                    <Button Content="Отмена"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Height="32"
                            Margin="5,0,0,0"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>