<Window x:Class="lc.Views.Windows.ReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:lc.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Ридер"
        Width="620"
        Height="750"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="☁ LibCloud"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="Bold"
                               FontSize="14"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="—" Style="{DynamicResource CaptionButtonStyle}" Click="Minimize_Click"/>
                    <Button Content="☐" Style="{DynamicResource CaptionButtonStyle}" Click="Maximize_Click"/>
                    <Button Content="✕" Style="{DynamicResource CloseButtonStyle}" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{Binding BookTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Главы"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,4"/>

                    <ComboBox ItemsSource="{Binding Chapters}"
                              SelectedItem="{Binding SelectedChapter, Mode=TwoWay}"
                              Style="{DynamicResource ComboBoxBaseStyle}"
                              Margin="0,0,0,12"
                              IsEnabled="{Binding IsInitialized}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="Глава "/>
                                    <Run Text="{Binding ChapterNumber}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding Title}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{Binding ChapterTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding ChapterText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="15"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="Tomato"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>